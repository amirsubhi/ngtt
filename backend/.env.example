NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

DATABASE_URL=mysql://ngtt_user:password@127.0.0.1:3306/ngtt
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change_me_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_different_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

UPLOAD_PATH=/var/www/ngtt/uploads
UPLOAD_URL=http://localhost:4000/uploads

SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=noreply@ngtt.com
SMTP_PASS=smtp_password

TMDB_API_KEY=your_tmdb_api_key
